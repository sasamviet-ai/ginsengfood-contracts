{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/ops/v1/print-payload.schema.json",
  "title": "Print Payload",
  "description": "Print Payload v1 contract generated by the system for labels, QR, barcode, batch, MFG/HSD, and packaging print levels.",
  "$comment": "Sources: docs/documents/0. appendices/03-PRINTING-CODE-RULES.md and docs/documents/0. appendices/05-MATERIAL-PACKAGING-TAXONOMY.md. Printer devices consume payloads but are not source of truth.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "print_payload_id": {
      "type": "string",
      "minLength": 1
    },
    "print_level": {
      "type": "string",
      "enum": [
        "LEVEL_1_PACK",
        "LEVEL_2_BOX_OR_CARTON"
      ],
      "description": "Packaging/print level."
    },
    "source_object": {
      "$ref": "../common/source-ref.schema.json"
    },
    "batch_id": {
      "type": "string",
      "minLength": 1
    },
    "sku_id": {
      "type": "string",
      "minLength": 1
    },
    "mfg_date": {
      "type": "string",
      "format": "date"
    },
    "hsd_date": {
      "type": "string",
      "format": "date",
      "description": "Expiry/HSD date carried by the generated print payload."
    },
    "barcode_data": {
      "type": "string",
      "minLength": 1,
      "description": "System-generated barcode data. Printers must not invent barcode values."
    },
    "qr_payload_ref": {
      "type": "string",
      "minLength": 1,
      "description": "QR payload or QR registry reference generated by the system."
    },
    "trace_chain_ref": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generated_by": {
      "$ref": "../common/actor.schema.json"
    },
    "reprint_of_payload_id": {
      "type": "string",
      "minLength": 1
    },
    "audit_refs": {
      "type": "array",
      "items": {
        "$ref": "../common/audit.schema.json"
      }
    }
  },
  "required": [
    "print_payload_id",
    "print_level",
    "source_object",
    "batch_id",
    "generated_at"
  ]
}
