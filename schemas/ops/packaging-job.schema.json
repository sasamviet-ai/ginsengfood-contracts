{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/ops/v1/packaging-job.schema.json",
  "title": "Packaging Job",
  "description": "Packaging Job v1 contract for level 1 and level 2 packaging. Packaging does not create inventory or sellable status by itself.",
  "$comment": "Sources: PACK-01 packaging chain and Operational Forms FRM-18/FRM-19. TODO: packaging job status values are not fully specified.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "packaging_job_id": { "type": "string", "minLength": 1, "description": "Packaging job identifier." },
    "batch_id": { "type": "string", "minLength": 1, "description": "Batch being packaged." },
    "packaging_config_id": { "type": "string", "minLength": 1, "description": "Packaging config used." },
    "packaging_level": { "type": "string", "enum": ["LEVEL_1", "LEVEL_2"], "description": "Packaging level from Operational Forms FRM-18/FRM-19." },
    "status": { "type": "string", "description": "Packaging status. TODO: define official values." },
    "output_pack_quantity": { "$ref": "../common/quantity.schema.json" },
    "output_box_quantity": { "$ref": "../common/quantity.schema.json" },
    "output_carton_quantity": { "$ref": "../common/quantity.schema.json" },
    "evidence_refs": { "type": "array", "items": { "$ref": "../common/evidence-ref.schema.json" } },
    "audit_refs": { "type": "array", "items": { "$ref": "../common/audit.schema.json" } }
  },
  "required": ["packaging_job_id"]
}
