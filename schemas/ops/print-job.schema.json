{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/ops/v1/print-job.schema.json",
  "title": "Print Job",
  "description": "Print Job v1 contract. Print data is generated from operational source objects; printer-side codes are not source of truth.",
  "$comment": "Sources: docs/documents/0. appendices/03-PRINTING-CODE-RULES.md and docs/documents/0. appendices/05-MATERIAL-PACKAGING-TAXONOMY.md.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "print_job_id": { "type": "string", "minLength": 1, "description": "Print job identifier." },
    "batch_id": { "type": "string", "minLength": 1, "description": "Batch context." },
    "packaging_job_id": { "type": "string", "minLength": 1, "description": "Packaging job context." },
    "print_config_id": { "type": "string", "minLength": 1, "description": "Print config used." },
    "status": {
      "type": "string",
      "enum": [
        "PAYLOAD_GENERATED",
        "SENT_TO_PRINTER",
        "PRINTED",
        "PRINT_CONFIRMED",
        "REPRINT_REQUESTED",
        "REPRINT_APPROVED",
        "REPRINTED",
        "PRINT_ERROR",
        "CANCELLED"
      ],
      "description": "Print job status. Prefer enums/ops/print-job-status.yaml."
    },
    "generated_by_system": { "type": "boolean", "description": "True when print payload is generated by the system from operational source data." },
    "source_object": { "$ref": "../common/source-ref.schema.json" },
    "print_payload_id": { "type": "string", "minLength": 1, "description": "Generated print payload identifier." },
    "print_payload": { "$ref": "print-payload.schema.json" },
    "reprint_reason": { "type": "string", "minLength": 1, "description": "Required when the job is a reprint request or reprint execution." },
    "reprint_approved_by": { "$ref": "../common/actor.schema.json" },
    "qr_registry_id": { "type": "string", "minLength": 1, "description": "QR registry identifier when generated." },
    "barcode_registry_id": { "type": "string", "minLength": 1, "description": "Barcode registry identifier when generated." },
    "evidence_refs": { "type": "array", "items": { "$ref": "../common/evidence-ref.schema.json" } },
    "audit_refs": { "type": "array", "items": { "$ref": "../common/audit.schema.json" } }
  },
  "required": ["print_job_id", "status"]
}
