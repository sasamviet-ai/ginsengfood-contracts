{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/ops/v1/raw-material-receipt.schema.json",
  "title": "Raw Material Receipt",
  "description": "Raw Material Receipt v1 contract for intake before incoming QC and raw material lot readiness.",
  "$comment": "Sources: PACK-01 raw material intake chain and appendix OPF-01 raw material inbound assessment. TODO: receipt status list is not fully specified.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "raw_material_receipt_id": { "type": "string", "minLength": 1, "description": "Raw material receipt identifier." },
    "source_origin_id": { "type": "string", "minLength": 1, "description": "Source origin for received material." },
    "supplier_id": { "type": "string", "minLength": 1, "description": "Supplier when applicable." },
    "received_at": { "type": "string", "format": "date-time", "description": "Receipt timestamp." },
    "status": { "type": "string", "description": "Receipt status. TODO: define official receipt lifecycle." },
    "receipt_lines": {
      "type": "array",
      "description": "Received material lines.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "material_id": { "type": "string", "minLength": 1 },
          "raw_lot_code": { "type": "string", "minLength": 1 },
          "received_quantity": { "$ref": "../common/quantity.schema.json" }
        }
      }
    },
    "source_object": { "$ref": "../common/source-ref.schema.json" },
    "evidence_refs": { "type": "array", "items": { "$ref": "../common/evidence-ref.schema.json" } },
    "audit_refs": { "type": "array", "items": { "$ref": "../common/audit.schema.json" } }
  },
  "required": ["raw_material_receipt_id"]
}
