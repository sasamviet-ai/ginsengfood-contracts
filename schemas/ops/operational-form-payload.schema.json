{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/ops/v1/operational-form-payload.schema.json",
  "title": "Operational Form Payload",
  "description": "Per-form payload contract for FRM-01 through FRM-27. It records generated fields, operator-entered fields, action constraints, and status constraints without embedding workflow business logic.",
  "$comment": "Sources: docs/documents/0. appendices/01-OPERATIONAL-FORMS.md, docs/documents/0. appendices/02-AUTO-GENERATED-FORM-RULES.md, and docs/documents/2. pack/04-PACK-04-MISA-ACCOUNTING-HANDOFF.md.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "form_code": {
      "type": "string",
      "pattern": "^FRM-(0[1-9]|1[0-9]|2[0-7])$"
    },
    "deprecated_form_code_alias": {
      "type": "string",
      "pattern": "^OPF-(0[1-9]|1[0-2])$",
      "description": "Optional deprecated OPF compatibility alias supplied by a legacy consumer. The canonical payload key remains form_code."
    },
    "payload_version": {
      "type": "string",
      "minLength": 1
    },
    "source_object": {
      "$ref": "../common/source-ref.schema.json"
    },
    "generated_fields": {
      "type": "object",
      "description": "Fields inherited or generated from approved source objects. Consumers must not require manual re-entry for these fields.",
      "additionalProperties": true
    },
    "operator_fields": {
      "type": "object",
      "description": "Fields the source documents allow operators to enter or confirm.",
      "additionalProperties": true
    },
    "action_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "GENERATE",
              "SUBMIT",
              "CONFIRM",
              "APPROVE",
              "REJECT",
              "RETURN_FOR_FIX",
              "LOCK",
              "CANCEL",
              "REOPEN",
              "SYNC_TO_MISA",
              "PRINT",
              "REPRINT"
            ]
          },
          "requires_permission": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
          },
          "requires_evidence": {
            "type": "boolean"
          },
          "requires_audit": {
            "type": "boolean"
          },
          "requires_p0_clearance": {
            "type": "boolean"
          }
        },
        "required": [
          "action"
        ]
      }
    },
    "status_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "status": {
            "type": "string"
          },
          "allowed_next_statuses": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "terminal": {
            "type": "boolean"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "../common/evidence-ref.schema.json"
      }
    }
  },
  "required": [
    "form_code",
    "payload_version"
  ]
}
