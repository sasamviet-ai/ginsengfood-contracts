{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/ops/v1/sale-lock.schema.json",
  "title": "Sale Lock",
  "description": "Sale Lock v1 contract. Sale Lock / Stop Sale wins over Product Activation, consumer channels, quote/order, and field actions.",
  "$comment": "Sources: PACK-01 Sale Lock / Stop Sale. TODO: exact sale-lock transition model is not finalized.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "sale_lock_id": { "type": "string", "minLength": 1, "description": "Sale lock identifier." },
    "scope_type": { "type": "string", "enum": ["SKU", "BATCH", "LOT", "TRACE_CHAIN"], "description": "Scope blocked by sale lock." },
    "scope_id": { "type": "string", "minLength": 1, "description": "Identifier of locked scope." },
    "status": { "type": "string", "description": "Sale lock status. Prefer enums/ops/sale-lock-status.yaml." },
    "active": { "type": "boolean", "description": "True when sale lock is active." },
    "reason": { "type": "string", "minLength": 1, "description": "Reason for stop-sale/sale lock." },
    "recall_case_id": { "type": "string", "minLength": 1, "description": "Linked recall case when sale lock comes from recall." },
    "effective_from": { "type": "string", "format": "date-time", "description": "Effective start time." },
    "effective_to": { "type": "string", "format": "date-time", "description": "Effective end time when released." },
    "owner_approval_ref": { "$ref": "../common/owner-decision-ref.schema.json" },
    "evidence_refs": { "type": "array", "items": { "$ref": "../common/evidence-ref.schema.json" } },
    "audit_refs": { "type": "array", "items": { "$ref": "../common/audit.schema.json" } }
  },
  "required": ["sale_lock_id"]
}
