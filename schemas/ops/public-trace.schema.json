{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/ops/v1/public-trace.schema.json",
  "title": "Public Trace",
  "description": "Public Trace v1 contract for whitelist-only QR trace exposure.",
  "$comment": "Sources: docs/software-specs/api/02_API_ENDPOINT_CATALOG.md Public Trace DTO Contract and packages/api-contracts PublicTracePublicResponse.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "public-trace.v1",
      "description": "Public trace schema version."
    },
    "traceStatus": {
      "type": "string",
      "enum": ["VALID", "NOT_PUBLIC", "INVALID_QR"],
      "description": "Public-safe trace lookup status."
    },
    "qr": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "qrStatusPublic": {
          "type": "string",
          "enum": ["PRINTED"],
          "description": "Public-safe QR status when the trace is valid."
        }
      }
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "productName": {
          "type": "string",
          "minLength": 1,
          "description": "Public product display name."
        }
      }
    },
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "batchPublicCode": {
          "type": "string",
          "minLength": 1,
          "description": "Public-safe batch code."
        },
        "releasePublicStatus": {
          "type": "string",
          "enum": ["RELEASED", "NOT_RELEASED", "HELD", "RECALLED"],
          "description": "Public-safe release status."
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceZoneName": {
          "type": "string",
          "minLength": 1,
          "description": "Public approved source zone name."
        },
        "province": {
          "type": "string",
          "minLength": 1,
          "description": "Public approved province."
        },
        "ward": {
          "type": "string",
          "minLength": 1,
          "description": "Public approved ward."
        },
        "addressDetail": {
          "type": "string",
          "minLength": 1,
          "description": "Public approved address text."
        }
      }
    },
    "originProofs": {
      "type": "array",
      "description": "Public-safe origin image/proof entries. Public URL must be sanitized by ops-core and must not expose storage paths or internal identifiers.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "proofType": {
            "type": "string",
            "enum": ["FIELD_PHOTO", "FIELD_VIDEO", "CERTIFICATE_DOC", "LAB_REPORT", "OTHER"],
            "description": "Public-safe proof type."
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "description": "Public-safe proof title."
          },
          "publicUrl": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://",
            "description": "Public HTTPS URL for the origin proof asset."
          },
          "mimeType": {
            "type": "string",
            "enum": ["image/jpeg", "image/png", "image/webp", "video/mp4", "video/quicktime", "application/pdf"],
            "description": "Public-safe media MIME type."
          }
        },
        "required": ["proofType", "publicUrl"]
      }
    },
    "messages": {
      "type": "array",
      "description": "Public-safe messages for unavailable or invalid traces.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["INFO", "WARNING"]
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["type", "text"]
      }
    }
  },
  "required": ["schemaVersion", "traceStatus", "qr", "product", "batch", "source", "originProofs", "messages"]
}
