{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "events/ops-core/recall/stop-sale-required.v1.json",
  "title": "Stop Sale Required Event v1",
  "description": "Published when stop-sale is required for a scope. This is a high-risk suppression signal and must not be ignored by consumer channels.",
  "$comment": "Sources: PACK-01 Recall Stop-Sale Gate; MASTER-07 stop-sale governance.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1,
      "description": "Unique event identifier."
    },
    "eventType": {
      "type": "string",
      "const": "ops-core.recall.stop-sale-required.v1",
      "description": "Stable event type including source, domain, name, and v1 suffix."
    },
    "eventVersion": {
      "type": "string",
      "const": "1.0",
      "description": "Event contract version."
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "Time the domain event occurred."
    },
    "source": {
      "type": "string",
      "const": "ops-core",
      "description": "System that owns and emits this event."
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "description": "Cross-system correlation identifier."
    },
    "causationId": {
      "type": "string",
      "minLength": 1,
      "description": "Optional parent command, event, or workflow identifier."
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1,
      "description": "Required when emitted from retryable or high-risk command; optional for derived read-model notifications."
    },
    "data": {
      "allOf": [
        {
          "$ref": "../../../schemas/ops/sale-lock.schema.json"
        },
        {
          "type": "object",
          "required": [
            "sale_lock_id",
            "scope_type",
            "scope_id",
            "active",
            "reason"
          ],
          "properties": {
            "active": {
              "const": true
            }
          }
        }
      ]
    }
  },
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "source",
    "correlationId",
    "data"
  ]
}
