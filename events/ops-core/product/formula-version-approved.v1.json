{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "events/ops-core/product/formula-version-approved.v1.json",
  "title": "Formula Version Approved Event v1",
  "description": "Published when a Formula Version is approved. Used formulas must not be overwritten; later changes require a new version.",
  "$comment": "Sources: PACK-02 G0/G1 boundary; PACK-03 formula scaling.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1,
      "description": "Unique event identifier."
    },
    "eventType": {
      "type": "string",
      "const": "ops-core.product.formula-version-approved.v1",
      "description": "Stable event type including source, domain, name, and v1 suffix."
    },
    "eventVersion": {
      "type": "string",
      "const": "1.0",
      "description": "Event contract version."
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "Time the domain event occurred."
    },
    "source": {
      "type": "string",
      "const": "ops-core",
      "description": "System that owns and emits this event."
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "description": "Cross-system correlation identifier."
    },
    "causationId": {
      "type": "string",
      "minLength": 1,
      "description": "Optional parent command, event, or workflow identifier."
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1,
      "description": "Required when emitted from retryable or high-risk command; optional for derived read-model notifications."
    },
    "data": {
      "allOf": [
        {
          "$ref": "../../../schemas/product/formula-version.schema.json"
        },
        {
          "type": "object",
          "required": [
            "formula_version_id",
            "generation",
            "status",
            "sku_id"
          ]
        }
      ]
    }
  },
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "source",
    "correlationId",
    "data"
  ]
}
