{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "events/ops-core/evidence/evidence-accepted.v1.json",
  "title": "Evidence Accepted Event v1",
  "description": "Published when a source-backed evidence registry record is accepted for a contract, release, smoke, security, or P0 gate.",
  "$comment": "Sources: docs/documents/1. master/06-MASTER-05-EVIDENCE-SMOKE-COMPLETION-GATE.md, docs/documents/2. pack/10-PACK-10-COMPLETION-EVIDENCE-GATEWAY.md, and docs/documents/3. tech/11-TECH-10-GLOBAL-SMOKE-UAT-EVIDENCE-RELEASE-GATEWAY-PRODUCTION-READINESS-CONTROL.md.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "eventType": {
      "type": "string",
      "const": "ops-core.evidence.evidence-accepted.v1"
    },
    "eventVersion": {
      "type": "string",
      "const": "1.0"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "const": "ops-core"
    },
    "correlationId": {
      "type": "string",
      "minLength": 1
    },
    "causationId": {
      "type": "string",
      "minLength": 1
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    },
    "data": {
      "allOf": [
        {
          "$ref": "../../../schemas/common/evidence-registry.schema.json"
        },
        {
          "type": "object",
          "required": [
            "evidenceId",
            "evidenceType",
            "status",
            "sourceDocument",
            "sourceRule",
            "scope"
          ]
        }
      ]
    }
  },
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "source",
    "correlationId",
    "data"
  ]
}
