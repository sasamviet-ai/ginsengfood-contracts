{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "events/ops-core/misa/accounting-handoff-created.v1.json",
  "title": "Accounting Handoff Created Event v1",
  "description": "Published when an accounting handoff contract is created from a valid operational checkpoint. It does not modify Operational Truth.",
  "$comment": "Sources: PACK-04 MISA Handoff and canonical FRM-14 accounting material issue / FRM-25 handoff record.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1,
      "description": "Unique event identifier."
    },
    "eventType": {
      "type": "string",
      "const": "ops-core.misa.accounting-handoff-created.v1",
      "description": "Stable event type including source, domain, name, and v1 suffix."
    },
    "eventVersion": {
      "type": "string",
      "const": "1.0",
      "description": "Event contract version."
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "Time the domain event occurred."
    },
    "source": {
      "type": "string",
      "const": "ops-core",
      "description": "System that owns and emits this event."
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "description": "Cross-system correlation identifier."
    },
    "causationId": {
      "type": "string",
      "minLength": 1,
      "description": "Optional parent command, event, or workflow identifier."
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1,
      "description": "Required when emitted from retryable or high-risk command; optional for derived read-model notifications."
    },
    "data": {
      "allOf": [
        {
          "$ref": "../../../schemas/ops/misa-handoff.schema.json"
        },
        {
          "type": "object",
          "required": [
            "misa_handoff_id",
            "operational_checkpoint_id",
            "checkpoint_type",
            "mapping_status",
            "sync_status"
          ]
        }
      ]
    }
  },
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "source",
    "correlationId",
    "data"
  ]
}
