{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "events/ops-core/inventory/stock-below-threshold.v1.json",
  "title": "Stock Below Threshold Event v1",
  "description": "Published when stock crosses a warning threshold. Stock alert is a signal and must not create Production Order directly.",
  "$comment": "Sources: PACK-03 Stock Alert; Muc canh bao ton kho san pham.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1,
      "description": "Unique event identifier."
    },
    "eventType": {
      "type": "string",
      "const": "ops-core.inventory.stock-below-threshold.v1",
      "description": "Stable event type including source, domain, name, and v1 suffix."
    },
    "eventVersion": {
      "type": "string",
      "const": "1.0",
      "description": "Event contract version."
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "Time the domain event occurred."
    },
    "source": {
      "type": "string",
      "const": "ops-core",
      "description": "System that owns and emits this event."
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "description": "Cross-system correlation identifier."
    },
    "causationId": {
      "type": "string",
      "minLength": 1,
      "description": "Optional parent command, event, or workflow identifier."
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1,
      "description": "Required when emitted from retryable or high-risk command; optional for derived read-model notifications."
    },
    "data": {
      "allOf": [
        {
          "$ref": "../../../schemas/ops/stock-alert.schema.json"
        },
        {
          "type": "object",
          "required": [
            "stock_alert_id",
            "sku_id",
            "status",
            "available_stock"
          ]
        }
      ]
    }
  },
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "source",
    "correlationId",
    "data"
  ]
}
