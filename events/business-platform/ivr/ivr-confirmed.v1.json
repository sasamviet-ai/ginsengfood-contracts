{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "events/business-platform/ivr/ivr-confirmed.v1.json",
  "title": "Ivr Confirmed Event v1",
  "description": "Published when IVR result is confirmed by the customer. It is an input signal only and must pass Core Order State Machine.",
  "$comment": "Sources: PACK-09 IVR_CONFIRMED; TECH-09 Core Order State Machine control.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1,
      "description": "Unique event identifier."
    },
    "eventType": {
      "type": "string",
      "const": "business-platform.ivr.ivr-confirmed.v1",
      "description": "Stable event type including source, domain, name, and v1 suffix."
    },
    "eventVersion": {
      "type": "string",
      "const": "1.0",
      "description": "Event contract version."
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "Time the domain event occurred."
    },
    "source": {
      "type": "string",
      "const": "business-platform",
      "description": "System that owns and emits this event."
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "description": "Cross-system correlation identifier."
    },
    "causationId": {
      "type": "string",
      "minLength": 1,
      "description": "Optional parent command, event, or workflow identifier."
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1,
      "description": "Required when emitted from retryable or high-risk command; optional for derived read-model notifications."
    },
    "data": {
      "allOf": [
        {
          "$ref": "../../../schemas/ivr/ivr-call-result.schema.json"
        },
        {
          "type": "object",
          "required": [
            "ivr_call_result_id",
            "version",
            "official_order_id",
            "final_result_status",
            "input_signal_only",
            "no_direct_order_update",
            "no_payment_or_revenue_effect",
            "core_order_handoff_required"
          ],
          "properties": {
            "final_result_status": {
              "const": "IVR_CONFIRMED"
            },
            "input_signal_only": {
              "const": true
            },
            "no_direct_order_update": {
              "const": true
            },
            "no_payment_or_revenue_effect": {
              "const": true
            }
          }
        }
      ]
    }
  },
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "source",
    "correlationId",
    "data"
  ]
}
