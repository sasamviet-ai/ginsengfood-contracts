{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "events/business-platform/demand/campaign-demand-forecasted.v1.json",
  "title": "Campaign Demand Forecasted Event v1",
  "description": "Published when campaign demand is forecasted. Forecast is planning input only and cannot bypass MRP, stock, sale-lock, or owner approval.",
  "$comment": "Sources: PACK-03 Demand/MRP; PACK-07 campaign measurement.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1,
      "description": "Unique event identifier."
    },
    "eventType": {
      "type": "string",
      "const": "business-platform.demand.campaign-demand-forecasted.v1",
      "description": "Stable event type including source, domain, name, and v1 suffix."
    },
    "eventVersion": {
      "type": "string",
      "const": "1.0",
      "description": "Event contract version."
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "Time the domain event occurred."
    },
    "source": {
      "type": "string",
      "const": "business-platform",
      "description": "System that owns and emits this event."
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "description": "Cross-system correlation identifier."
    },
    "causationId": {
      "type": "string",
      "minLength": 1,
      "description": "Optional parent command, event, or workflow identifier."
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1,
      "description": "Required when emitted from retryable or high-risk command; optional for derived read-model notifications."
    },
    "data": {
      "allOf": [
        {
          "$ref": "../../../schemas/ops/demand.schema.json"
        },
        {
          "type": "object",
          "required": [
            "demand_id",
            "sku_id",
            "demand_source",
            "required_quantity"
          ]
        }
      ]
    }
  },
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "source",
    "correlationId",
    "data"
  ]
}
