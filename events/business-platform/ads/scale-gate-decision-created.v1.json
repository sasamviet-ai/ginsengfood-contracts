{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "events/business-platform/ads/scale-gate-decision-created.v1.json",
  "title": "Scale Gate Decision Created Event v1",
  "description": "Published when a scale gate decision is created. Scale gate is not an automatic budget increase and requires owner decision.",
  "$comment": "Sources: PACK-07 Scale Gate; TECH-07 Scale Gate review.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1,
      "description": "Unique event identifier."
    },
    "eventType": {
      "type": "string",
      "const": "business-platform.ads.scale-gate-decision-created.v1",
      "description": "Stable event type including source, domain, name, and v1 suffix."
    },
    "eventVersion": {
      "type": "string",
      "const": "1.0",
      "description": "Event contract version."
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "Time the domain event occurred."
    },
    "source": {
      "type": "string",
      "const": "business-platform",
      "description": "System that owns and emits this event."
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "description": "Cross-system correlation identifier."
    },
    "causationId": {
      "type": "string",
      "minLength": 1,
      "description": "Optional parent command, event, or workflow identifier."
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1,
      "description": "Required when emitted from retryable or high-risk command; optional for derived read-model notifications."
    },
    "data": {
      "allOf": [
        {
          "$ref": "../../../schemas/ads/scale-gate.schema.json"
        },
        {
          "type": "object",
          "required": [
            "scale_gate_id",
            "version",
            "owner_decision",
            "scale_decision",
            "no_auto_scale_without_owner_approval"
          ],
          "properties": {
            "no_auto_scale_without_owner_approval": {
              "const": true
            }
          }
        }
      ]
    }
  },
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "source",
    "correlationId",
    "data"
  ]
}
